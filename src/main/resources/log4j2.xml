<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <!-- Properties -->
    <Properties>
        <Property name="logDir">logs</Property>
        <Property name="logFileName">automation.log</Property>
        <Property name="pattern">
            %d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n
        </Property>
    </Properties>

    <!-- Appenders -->
    <Appenders>

        <!-- Console Appender -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="${pattern}"/>
        </Console>

        <!-- File Appender -->
        <File name="FileAppender"
              fileName="${logDir}/${logFileName}"
              append="true">
            <PatternLayout pattern="${pattern}"/>
        </File>

        <!-- Rolling File Appender (Optional but Recommended) -->
        <RollingFile name="RollingFileAppender"
                     fileName="${logDir}/${logFileName}"
                     filePattern="${logDir}/archive/automation-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${pattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
                <SizeBasedTriggeringPolicy size="5 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="5"/>
        </RollingFile>

    </Appenders>

    <!-- Loggers -->
    <Loggers>

        <!-- Framework Logs -->
        <Logger name="org.openqa.selenium" level="INFO" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="RollingFileAppender"/>
        </Logger>

        <!-- TestNG Logs -->
        <Logger name="org.testng" level="INFO" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="RollingFileAppender"/>
        </Logger>

        <!-- Your Project Logs -->
        <Logger name="com.yourpackage" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="RollingFileAppender"/>
        </Logger>

        <!-- Root Logger -->
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="RollingFileAppender"/>
        </Root>

    </Loggers>

</Configuration>